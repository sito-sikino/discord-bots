# Discord Bot Tokens (各ボットの独立したトークン)
SPECTRA_DISCORD_TOKEN=your_spectra_bot_token_here
LYNQ_DISCORD_TOKEN=your_lynq_bot_token_here
PAZ_DISCORD_TOKEN=your_paz_bot_token_here

# Discord Server Settings
DISCORD_GUILD_ID=your_discord_server_id_here

# Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here

# LangSmith Settings (Optional - for monitoring & tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here

# MCP (Model Context Protocol) Settings
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
MCP_SERVER_URL=http://localhost:8080

# System Configuration
LIGHTWEIGHT_DECISION_ENABLED=true
COLLABORATION_MODE=sequential
LLM_ACCESS_TIMEOUT=10

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=structured

# Development Settings
ENVIRONMENT=development
DEBUG=true